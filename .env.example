# ============================================================
# Variables de entorno necesarias
# ============================================================
# Copia este archivo a `.env` y rellena los valores para correr local.
# En GitHub Actions estos valores van como Secrets del repositorio.

# The Odds API — https://the-odds-api.com/
# Free tier: 500 requests/mes (suficiente para 2 scans al día en 7 ligas)
ODDS_API_KEY=

# Bot de Telegram — habla con @BotFather para crear uno
TELEGRAM_BOT_TOKEN=

# Tu chat ID o ID del canal donde recibir señales
# Descúbrelo hablando con @userinfobot
TELEGRAM_CHANNEL_ID=

# (Opcional) healthchecks.io — te avisa si el workflow deja de correr
# HEALTHCHECK_URL=https://hc-ping.com/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
